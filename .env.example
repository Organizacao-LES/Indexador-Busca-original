# Database
DATABASE_USER=admin
DATABASE_PASSWORD=admin
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_URL=postgres://%DATABASE_USER%:%DATABASE_PASSWORD%@%DATABASE_HOST%:%DATABASE_PORT%/ifesdoc

# Security
SECRET_KEY=change_this_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SESSION_IDLE_EXPIRE_MINUTES=30
BACKEND_CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080"]

# Environment
ENVIRONMENT=development

# Frontend
VITE_APP_NAME=IFESDOC
VITE_API_URL=http://localhost:8000
VITE_USE_MOCK_API=true

# SonarQube
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=change_this_token
